<?xml version="1.0" encoding="UTF-8"?>
<!-- Build with: candle.exe -dBinDir=... forgum.wxs && light.exe -out forgum.msi forgum.wixobj  (or `cargo wix`). WiX Toolset must be installed in the windows runner. -->
<!--
  Two components by design (each with one file OR one KeyPath - never
  both) so each can use a fixed GUID and a single KeyPath type:

   * MainExecutable         - per-machine binary, file KeyPath, fixed
                              GUID.
   * StartMenuShortcut      - per-user shortcut + HKCU registry, REGISTRY
                              KeyPath, fixed GUID.

  Previous attempts failed because:
    - Having registry + file + shortcut *inside one Component* triggers
      CNDL0230 ("Components with registry keypaths and files cannot
      use an automatically generated guid") and was previously
      masked by Microsoft ICE43 only because the auto-guid was the
      same across reinstalls (which broke upgrade repair rules).

    - Putting <RemoveFile>/<RemoveFolder> inside <Directory> triggers
      CNDL0005 (unexpected child element). They're Component-level
      actions.

  All ICEs here are resolved by clean separation:
    ICE43  - shortcut component uses HKCU registry as KeyPath
             (not a file).
    ICE57  - shortcut component is per-user only (HKCU + HKCU-keyed
             shortcut), no per-machine data inside it.
    ICE64  - <RemoveFile Name="*" On="uninstall"/> lives on the
             shortcut component, inside the user-profile directory.
    ICE69  - shortcut shares its Component with the HKCU registry,
             its own file-less identity, so no cross-component target.
    ICE80  - <Package Platform="x64"/> sets the MSI Template
             Summary Property so x64-only components are valid.

  The shortcut's "Directory=ProgramMenuDir" attribute owns the
  wiring into ProgramMenuFolder cascade. The <Component>/<Directory>
  hierarchy here matches: directory structure → ownership of (file
  and/or registry + RemoveFile) per Component, not raw layout.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="Forgum" Language="1033" Version="0.4.0" Manufacturer="HKDevLoops" UpgradeCode="AE18D640-560C-4B78-9E7F-557CF387312F">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" Platform="x64" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Forgum is already installed." />
    <MediaTemplate />
    <Feature Id="ProductFeature" Title="Forgum" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Forgum">
          <Component Id="MainExecutable" Guid="11330A1F-8B40-4E13-9F62-A8A4B619D0F1" Win64="yes">
            <File Id="forgumEngineExe" Source="$(var.BinDir)\forgum-engine.exe" KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ProgramMenuDir" Name="Forgum">
          <Component Id="StartMenuShortcut" Guid="22330A2F-8B40-4E13-9F62-A8A4B619D0F2">
            <Shortcut Id="StartMenuForgum"
                      Name="Forgum"
                      Target="[INSTALLFOLDER]forgum-engine.exe"
                      WorkingDirectory="INSTALLFOLDER" />
            <RegistryValue Root="HKCU"
                           Key="Software\HKDevLoops\Forgum"
                           Name="installed"
                           Type="integer"
                           Value="1"
                           KeyPath="yes" />
            <!-- ICE64: explicitly remove the shortcut on uninstall so the
                 user-profile directory is wiped clean. -->
            <RemoveFile Id="CleanStartMenuShortcut" On="uninstall" Name="*" />
            <RemoveFolder Id="RemoveProgramMenuDir" On="uninstall" />
          </Component>
        </Directory>
      </Directory>
    </Directory>
    <ComponentGroup Id="ProductComponents">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="StartMenuShortcut" />
    </ComponentGroup>
  </Product>
</Wix>
